{
  "name": "iina-jellyfin-integration",
  "version": "0.2.0",
  "private": true,
  "description": "An IINA-native Direct Mode client for Jellyfin.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/germagla/iina-jellyfin-integration.git"
  },
  "bugs": {
    "url": "https://github.com/germagla/iina-jellyfin-integration/issues"
  },
  "homepage": "https://github.com/germagla/iina-jellyfin-integration#readme",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm clean && pnpm --filter @iina-jellyfin/core build && pnpm --filter @iina-jellyfin/ui build && pnpm --filter @iina-jellyfin/plugin build && pnpm package:validate",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm format:check && pnpm build",
    "clean": "rimraf dist coverage .artifacts",
    "dev": "pnpm --filter @iina-jellyfin/ui dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "iina:link": "pnpm build && node scripts/link-development-plugin.mjs",
    "iina:unlink": "/Applications/IINA.app/Contents/MacOS/iina-plugin unlink .",
    "lint": "eslint .",
    "package:archive": "pnpm build && node scripts/create-archive.mjs",
    "package:validate": "node scripts/validate-package.mjs",
    "release:validate": "node scripts/validate-release.mjs",
    "test": "node --test scripts/release-version.test.mjs scripts/release-notes.test.mjs && pnpm -r --if-present test",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  }
}
