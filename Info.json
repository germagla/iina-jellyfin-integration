{
  "name": "Jellyfin for IINA",
  "identifier": "dev.germagla.iina-jellyfin",
  "version": "0.1.0",
  "description": "Browse and play movies and television from Jellyfin in an IINA-native Direct Mode experience.",
  "ghRepo": "germagla/iina-jellyfin-integration",
  "author": {
    "name": "Germagla"
  },
  "entry": "dist/index.js",
  "globalEntry": "dist/global.js",
  "permissions": ["network-request", "show-osd", "video-overlay", "file-system"],
  "allowedDomains": ["*"],
  "sidebarTab": {
    "name": "Jellyfin"
  },
  "preferenceDefaults": {
    "connectionMetadata": "",
    "deviceId": "",
    "autoplayNextEpisode": true,
    "foregroundPollSeconds": 60,
    "artworkCacheMaxBytes": 52428800
  }
}
